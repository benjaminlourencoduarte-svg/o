function hide()
	for i,invisibleparts in pairs(workspace:GetDescendants()) do
		if invisibleparts:IsA("BasePart") and invisibleparts.Transparency == 1 then
			function findhumanoid()
				if invisibleparts.Parent:FindFirstChild("Humanoid") then
					return invisibleparts.Parent.Humanoid
				end
			end
			if findhumanoid() then
				return
			end
			invisibleparts.CanCollide = false
			invisibleparts.CanTouch = false
			invisibleparts.CanQuery = false
		end
	end

end
