local DebugLog = G.Luma_DebugLog
function logDebug(...)
	local msg = table.concat({...}, " ")
	table.insert(DebugLog, 1, os.date("%X") .. " - " .. msg)
	if #DebugLog > 300 then table.remove(DebugLog) end
	print("[LumaHub DEBUG]", msg)
end
function logWarn(msg)
	warn("[LumaHub - Warn] "..msg)
end
